package kotoba:dom@0.1.0;

/// DOM-like rendering ABI for kotoba WASM guests.
///
/// The guest owns ids and emits deterministic operations. The host decides how
/// to realize them: native widgets, retained virtual DOM, WebGL quads/glyphs,
/// WebGPU scene buffers, or a browser bridge.
interface renderer {
  type node-id = u64;
  type handler-id = u64;

  record input-event {
    target: node-id,
    name: string,
    x: float64,
    y: float64,
    value: option<string>,
    key: option<string>,
  }

  create-element: func(id: node-id, tag: string);
  create-text: func(id: node-id, text: string);
  set-root: func(id: node-id);
  set-attr: func(id: node-id, namespace: option<string>, name: string, value: string);
  append-child: func(parent: node-id, child: node-id);
  remove-children: func(id: node-id);
  add-event-listener: func(id: node-id, name: string, handler: handler-id);

  /// Present the current committed tree. A WebGL/WebGPU host can use this as
  /// the frame boundary after layout/text shaping.
  present: func();

  /// Host-driven event polling. The guest maps handler-id back to the registered
  /// Reagent-style callback.
  poll-event: func() -> option<tuple<handler-id, input-event>>;
}

world kotoba-dom-guest {
  import renderer;
}
